# App
ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./data/darth_schwader.db
LOG_LEVEL=INFO

# Schwab
# Register an app at https://developer.schwab.com and set the callback URL to your local HTTPS callback.
SCHWAB_CLIENT_ID=your_schwab_app_key
SCHWAB_CLIENT_SECRET=your_schwab_app_secret
SCHWAB_REDIRECT_URI=https://127.0.0.1:8000/api/v1/broker/oauth/callback
SCHWAB_ACCOUNT_NUMBER=your_broker_account_number

# Secrets
# Generate a Fernet key with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=replace_with_fernet_base64_key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
POLYGON_API_KEY=

# Account semantics
ACCOUNT_TYPE=CASH
OPTIONS_APPROVAL_TIER=2
WATCHLIST=SPY,QQQ,IWM,AAPL,NVDA,TSLA,MSFT,META

# Trading controls
PAPER_TRADING=true
HITL_REQUIRED=true
ALLOW_NAKED=false

# Risk defaults
MAX_RISK_PER_TRADE_PCT=0.25
PREFERRED_MAX_RISK_PER_TRADE_PCT=0.05
MAX_DAILY_DRAWDOWN_PCT=0.05
MAX_WEEKLY_DRAWDOWN_PCT=0.10
MAX_POSITIONS=5
MAX_UNDERLYING_ALLOCATION_PCT=0.20
MIN_DTE_DAYS=14
MAX_DTE_DAYS=60

# AI / market data
AI_PROVIDER=claude
IV_SPIKE_THRESHOLD_PCT=90
POLYGON_BACKFILL_DAYS=365
